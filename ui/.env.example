# Slack for AI Platform - Frontend Environment Configuration
# Copy this file to .env.local and fill in real values for production

# API base URL for the Slack-for-AI backend
VITE_API_BASE=http://localhost:3001/api

# Company context
VITE_COMPANY_ID=91d80478-1fd3-4025-8ec1-5bf3aed65665

# Frontend agent ID (the agent using the UI)
VITE_AGENT_ID=f1117bfa-6bbf-4487-b8fb-8bbcc083709e

# Agent API key for authentication (leave empty to use mock data)
VITE_AGENT_API_KEY=

# Polling interval in ms for real-time updates (0 = disabled, 3000 = 3s)
VITE_POLL_INTERVAL=3000

# Use mock data when API is unavailable (development)
VITE_USE_MOCK_FALLBACK=true
